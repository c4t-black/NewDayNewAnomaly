<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            prefHeight="400.0" prefWidth="500.0"
            style="-fx-background-color: #1a1a1a; -fx-border-color: #8B7355; -fx-border-width: 3;">

    <!-- Título -->
    <Label text="DOCUMENTOS" layoutX="0" layoutY="10"
           prefWidth="500.0" alignment="CENTER"
           textFill="WHITE">
        <font>
            <Font name="Bernard MT Condensed" size="28.0"/>
        </font>
    </Label>

    <!-- Botão fechar -->
    <Button fx:id="closeBtn" text="✕"
            layoutX="460.0" layoutY="8.0"
            prefWidth="32.0" prefHeight="28.0"
            style="-fx-background-color: #8B0000; -fx-text-fill: white; -fx-cursor: hand;"/>

    <!-- Conteúdo dos papers -->
    <VBox layoutX="20.0" layoutY="60.0" spacing="15.0" prefWidth="460.0">

        <Label text="• Formulário de Identificação" textFill="#cccccc">
            <font><Font name="Felix Titling" size="16.0"/></font>
        </Label>

        <Label text="• Relatório Diário" textFill="#cccccc">
            <font><Font name="Felix Titling" size="16.0"/></font>
        </Label>

        <Label text="• Registro de Anomalias" textFill="#cccccc">
            <font><Font name="Felix Titling" size="16.0"/></font>
        </Label>

    </VBox>


</AnchorPane>