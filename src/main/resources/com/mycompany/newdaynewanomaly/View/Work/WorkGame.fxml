<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.effect.Bloom?>
<?import javafx.scene.effect.Light.Distant?>
<?import javafx.scene.effect.Lighting?>
<?import javafx.scene.effect.Shadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<ScrollPane blendMode="DARKEN" hbarPolicy="NEVER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" pannable="true" prefHeight="1155.0" prefWidth="1827.0" stylesheets="@../../CSS/Room.css" vbarPolicy="NEVER" vvalue="1.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.newdaynewanomaly.Controller.Gameplay.GameplayController">

    <AnchorPane prefHeight="419.0" prefWidth="1.0" style="-fx-background-color: black;">

        <ImageView fitHeight="945.0" fitWidth="1647.0" layoutX="9.0" layoutY="17.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@../../Images/Rooms/BackWorkRoom.png" />
            </image>
        </ImageView>

        <!-- PESSOA -->
        <ImageView fx:id="pessoa" fitHeight="633.0" fitWidth="426.0" layoutX="695.0" layoutY="312.0" pickOnBounds="true" preserveRatio="true">
            <effect>
                <Bloom threshold="1.0">
                    <input>
                        <Lighting diffuseConstant="1.56" specularConstant="2.0" specularExponent="40.0">
                            <bumpInput>
                                <Shadow height="41.4" radius="20.2" width="41.4" />
                            </bumpInput>
                            <light>
                                <Light.Distant>
                                    <color>
                                        <Color red="0.7787933349609375" green="0.811302661895752" blue="0.42119041085243225" />
                                    </color>
                                </Light.Distant>
                            </light>
                        </Lighting>
                    </input>
                </Bloom>
            </effect>
        </ImageView>

        <!-- BACKGROUND -->
        <ImageView fitHeight="962.0" fitWidth="1678.0" layoutX="-5.0" layoutY="-10.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@../../Images/Rooms/WorkRoom.png" />
            </image>
        </ImageView>

        <!-- RADIO -->
        <Label fx:id="speechRadio" alignment="CENTER" layoutX="1117.0" layoutY="520.0" prefHeight="56.0" prefWidth="340.0" style="-fx-background-color: white;" styleClass="corner" text="prepare to work" textFill="#2e2c2c" visible="false">
            <font>
                <Font name="Bernard MT Condensed" size="34.0" />
            </font>
        </Label>

        <!-- ASK -->
        <Button fx:id="askBtn" layoutX="686.0" layoutY="358.0" mnemonicParsing="false" onAction="#onAsk" prefHeight="60.0" prefWidth="120.0" text="Ask" visible="false" />

        <!-- Botões de pergunta (aparecem ao clicar em Ask) -->
        <Button fx:id="askNomeBtn" layoutX="613.0" layoutY="289.0" mnemonicParsing="false" onAction="#onAskNome" prefHeight="45.0" prefWidth="150.0" text="Nome" visible="false" />

        <Button fx:id="askIdadeBtn" layoutX="512.0" layoutY="366.0" mnemonicParsing="false" onAction="#onAskIdade" prefHeight="45.0" prefWidth="150.0" text="Idade" visible="false" />

        <Button fx:id="askCidadeBtn" layoutX="595.0" layoutY="439.0" mnemonicParsing="false" onAction="#onAskCidade" prefHeight="45.0" prefWidth="150.0" text="Cidade de Origem" visible="false" />

        <!-- Speech Player -->
        <Label fx:id="speechPlayer" alignment="CENTER" layoutX="703.0" layoutY="591.0" prefHeight="58.0" prefWidth="393.0" style="-fx-background-color: white;" styleClass="corner" text="NAME?" textFill="#2e2c2c" visible="false">
            <font>
                <Font name="Felix Titling" size="34.0" />
            </font>
        </Label>

        <!-- Speech Creature -->
        <Label fx:id="speechCreature" alignment="CENTER" layoutX="689.0" layoutY="272.0" prefHeight="75.0" prefWidth="418.0" style="-fx-background-color: white;" styleClass="corner" textFill="#2e2c2c" visible="false">
            <font>
                <Font name="Bernard MT Condensed" size="34.0" />
            </font>
        </Label>

        <!-- Nome -->
        <Button layoutX="1040.0" layoutY="363.0" mnemonicParsing="false" prefHeight="51.0" prefWidth="128.0" text="Nome" visible="false" />

        <!-- Cidade -->
        <Button layoutX="1077.0" layoutY="436.0" mnemonicParsing="false" prefHeight="51.0" prefWidth="128.0" text="Cidade" visible="false" />

        <!-- Papers -->
        <Button fx:id="papersBtn" layoutX="760.0" layoutY="665.0" mnemonicParsing="false" onAction="#openPapers" prefHeight="86.0" prefWidth="264.0" text="Papers" visible="false" />

        <!-- OVERLAY DO PAINEL DE PAPERS -->
        <AnchorPane fx:id="papersOverlay" layoutX="-5.0" layoutY="-10.0" prefHeight="962.0" prefWidth="1678.0" style="-fx-background-color: rgba(0,0,0,0.65);" visible="false">

            <!-- Painel central -->
            <AnchorPane layoutX="589.0" layoutY="281.0" prefHeight="400.0" prefWidth="500.0" style="-fx-background-color: #1a1a1a;                                -fx-border-color: #8B7355;                                -fx-border-width: 3;">

                <!-- Título -->
                <Label alignment="CENTER" layoutX="0" layoutY="10" prefWidth="500.0" text="DOCUMENTOS" textFill="WHITE">
                    <font>
                        <Font name="Bernard MT Condensed" size="28.0" />
                    </font>
                </Label>

                <!-- Botão fechar -->
                <Button layoutX="460.0" layoutY="8.0" onAction="#closePapers" prefHeight="28.0" prefWidth="32.0" style="-fx-background-color: #8B0000;                                -fx-text-fill: white;                                -fx-cursor: hand;" text="✕" />

                <!-- Nome -->
                <Label layoutX="20.0" layoutY="70.0" text="NOME:" textFill="#8B7355">
                    <font><Font name="Bernard MT Condensed" size="20.0" /></font>
                </Label>
                <Label fx:id="papersNome" layoutX="120.0" layoutY="70.0" textFill="#cccccc">
                    <font><Font name="Felix Titling" size="16.0" /></font>
                </Label>

                <!-- Cidade -->
                <Label layoutX="20.0" layoutY="115.0" text="CIDADE:" textFill="#8B7355">
                    <font><Font name="Bernard MT Condensed" size="20.0" /></font>
                </Label>
                <Label fx:id="papersCidade" layoutX="120.0" layoutY="115.0" textFill="#cccccc">
                    <font><Font name="Felix Titling" size="16.0" /></font>
                </Label>

                <!-- Idade -->
                <Label layoutX="20.0" layoutY="160.0" text="IDADE:" textFill="#8B7355">
                    <font><Font name="Bernard MT Condensed" size="20.0" /></font>
                </Label>
                <Label fx:id="papersIdade" layoutX="120.0" layoutY="160.0" textFill="#cccccc">
                    <font><Font name="Felix Titling" size="16.0" /></font>
                </Label>

                <!-- Gender -->
                <Label layoutX="20.0" layoutY="205.0" text="GÊNERO:" textFill="#8B7355">
                    <font><Font name="Bernard MT Condensed" size="20.0" /></font>
                </Label>
                <Label fx:id="papersGender" layoutX="120.0" layoutY="205.0" textFill="#cccccc">
                    <font><Font name="Felix Titling" size="16.0" /></font>
                </Label>

            </AnchorPane>
        </AnchorPane>

        <!-- Botão Veredicto (lado direito) -->
        <Button fx:id="verdictBtn" onAction="#openVerdict"
                layoutX="1550.0" layoutY="450.0"
                mnemonicParsing="false"
                prefHeight="80.0" prefWidth="80.0"
                text="⚖" visible="false"
                style="-fx-background-color: #1a1a1a;
               -fx-text-fill: #8B7355;
               -fx-border-color: #8B7355;
               -fx-border-width: 2;
               -fx-font-size: 28px;
               -fx-cursor: hand;" />

        <!-- OVERLAY DO VEREDICTO -->
        <AnchorPane fx:id="verdictOverlay"
                    prefHeight="962.0" prefWidth="1678.0"
                    layoutX="-5.0" layoutY="-10.0"
                    visible="false"
                    style="-fx-background-color: rgba(0,0,0,0.65);">

            <!-- Painel central -->
            <AnchorPane prefHeight="340.0" prefWidth="400.0"
                        layoutX="639.0" layoutY="311.0"
                        style="-fx-background-color: #1a1a1a;
                       -fx-border-color: #8B7355;
                       -fx-border-width: 2;">

                <!-- Título -->
                <Label text="VEREDICTO FINAL"
                       layoutX="0" layoutY="15"
                       prefWidth="400.0" alignment="CENTER"
                       textFill="#8B7355">
                    <font><Font name="Bernard MT Condensed" size="22.0" /></font>
                </Label>

                <!-- Botão fechar -->
                <Button onAction="#closeVerdict" text="✕"
                        layoutX="362.0" layoutY="10.0"
                        prefWidth="30.0" prefHeight="26.0"
                        style="-fx-background-color: #8B0000;
                       -fx-text-fill: white;" />

                <!-- Subtítulo -->
                <Label fx:id="verdictSubtitle"
                       text="Você analisou o indivíduo. Qual é o seu veredicto?"
                       layoutX="20.0" layoutY="55.0"
                       prefWidth="360.0" alignment="CENTER"
                       wrapText="true" textFill="#888888">
                    <font><Font name="Felix Titling" size="13.0" /></font>
                </Label>

                <!-- Botão NORMAL -->
                <Button fx:id="btnNormal" onAction="#onVerdictNormal"
                        layoutX="20.0" layoutY="120.0"
                        prefHeight="100.0" prefWidth="170.0"
                        text="✔  NORMAL"
                        style="-fx-background-color: #0d1f0d;
                       -fx-text-fill: #97C459;
                       -fx-border-color: #3B6D11;
                       -fx-border-width: 1.5;
                       -fx-font-size: 16px;
                       -fx-cursor: hand;" />

                <!-- Botão ANOMALIA -->
                <Button fx:id="btnAnomalia" onAction="#onVerdictAnomalia"
                        layoutX="210.0" layoutY="120.0"
                        prefHeight="100.0" prefWidth="170.0"
                        text="⚠  ANOMALIA"
                        style="-fx-background-color: #1f0d0d;
                       -fx-text-fill: #F09595;
                       -fx-border-color: #A32D2D;
                       -fx-border-width: 1.5;
                       -fx-font-size: 16px;
                       -fx-cursor: hand;" />

                <!-- Label de confirmação -->
                <Label fx:id="verdictConfirmLabel"
                       layoutX="20.0" layoutY="240.0"
                       prefWidth="360.0" alignment="CENTER"
                       wrapText="true" visible="false"
                       textFill="#cccccc">
                    <font><Font name="Felix Titling" size="13.0" /></font>
                </Label>

                <!-- Botão Cancelar -->
                <Button fx:id="verdictCancelBtn" onAction="#onVerdictCancel"
                        layoutX="60.0" layoutY="290.0"
                        prefHeight="35.0" prefWidth="120.0"
                        text="Cancelar" visible="false"
                        style="-fx-background-color: transparent;
                       -fx-text-fill: #aaaaaa;
                       -fx-border-color: #555555;
                       -fx-border-width: 1;" />

                <!-- Botão Confirmar -->
                <Button fx:id="verdictConfirmBtn" onAction="#onVerdictConfirm"
                        layoutX="220.0" layoutY="290.0"
                        prefHeight="35.0" prefWidth="120.0"
                        text="Confirmar" visible="false"
                        style="-fx-background-color: #3B6D11;
                       -fx-text-fill: white;
                       -fx-border-width: 0;" />

            </AnchorPane>
        </AnchorPane>

    </AnchorPane>
</ScrollPane>
