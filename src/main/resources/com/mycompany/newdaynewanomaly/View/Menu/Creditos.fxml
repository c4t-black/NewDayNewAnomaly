<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.Reflection?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<AnchorPane style="-fx-background-color: #2c2c2a;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.newdaynewanomaly.Controller.Menu.PrimaryController">

    <!-- VBox grudado nas 4 bordas = ocupa a tela toda -->
    <VBox alignment="CENTER" spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <!-- Título -->
        <Label alignment="CENTER" prefHeight="67.0" prefWidth="959.0" text="NEW DAY NEW ANOMALY" textFill="RED">
            <font>
                <Font name="Century" size="54.0" />
            </font>
            <effect>
                <Reflection fraction="0.87" topOpacity="0.65" />
            </effect>

            <VBox.margin>
                <Insets bottom="60.0" />   <!-- ← espaço entre título e linha -->
            </VBox.margin>
        </Label>

        <!-- Linha separadora -->
        <Line endX="398.0" startX="-100.0" stroke="RED" strokeWidth="2.0" />
      <Label alignment="TOP_CENTER" contentDisplay="TOP" prefHeight="68.0" prefWidth="230.0" text="Um Jogo Por:" textFill="WHITE">
         <font>
            <Font name="Bernard MT Condensed" size="36.0" />
         </font>
      </Label>
      <Label alignment="TOP_CENTER" contentDisplay="TOP" prefHeight="40.0" prefWidth="464.0" text="-{ LUIZ GABRIEL LIMA DE SOUZA }-" textFill="WHITE">
         <font>
            <Font name="Bernard MT Condensed" size="25.0" />
         </font>
      </Label>
      <Label alignment="TOP_CENTER" contentDisplay="TOP" prefHeight="86.0" prefWidth="464.0" text="-{ DAVI PALHARES DE BARROS VILARIM }-" textFill="WHITE">
         <font>
            <Font name="Bernard MT Condensed" size="25.0" />
         </font>
      </Label>
      <Label alignment="TOP_CENTER" contentDisplay="TOP" prefHeight="25.0" prefWidth="230.0" text="Orientador:" textFill="WHITE">
         <font>
            <Font name="Bernard MT Condensed" size="26.0" />
         </font>
      </Label>
      <Label alignment="TOP_CENTER" contentDisplay="TOP" prefHeight="84.0" prefWidth="230.0" text="Matheus Amado" textFill="WHITE">
         <font>
            <Font name="Bernard MT Condensed" size="26.0" />
         </font>
      </Label>
      <Button mnemonicParsing="false" prefHeight="26.0" prefWidth="91.0" text="Voltar" onAction="#ReturnToMenu">
         <font>
            <Font name="Baskerville Old Face" size="13.0" />
         </font>
      </Button>

    </VBox>

</AnchorPane>
