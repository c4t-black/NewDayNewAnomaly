<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="742.0" prefWidth="1116.0" style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.newdaynewanomaly.Controller.Gameplay.Lost">

    <children>
        <!-- Vignette overlay -->
        <Rectangle fx:id="vignette" height="781.0" mouseTransparent="true" style="-fx-fill: radial-gradient(center 50% 50%, radius 60%, transparent 0%, rgba(80,0,0,0.6) 100%);" width="1162.0" AnchorPane.leftAnchor="0" AnchorPane.topAnchor="0" />

        <VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="28.0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <!-- Main title -->
            <Label fx:id="titleLabel" style="-fx-effect: dropshadow(gaussian, #ff000066, 18, 0.4, 0, 0);                           -fx-translate-y: -8;" text="YOU LOSE" textFill="#C0001A">
                <font>
                    <Font name="Bookman Old Style Bold" size="72.0" />
                </font>
            </Label>

            <!-- Subtitle -->
            <Label fx:id="subtitleLabel" style="-fx-letter-spacing: 2;" text="YOUR SANITY HAS BEEN CONSUMED" textFill="#6B1A1A">
                <font>
                    <Font name="Bookman Old Style" size="13.0" />
                </font>
            </Label>

            <!-- Divider line -->
            <Rectangle height="1" style="-fx-fill: #3a0007;" width="180" />

            <!-- Return button -->
            <Button fx:id="menuButton" mnemonicParsing="false" onAction="#menu" prefHeight="42.0" prefWidth="200.0" style="-fx-background-color: transparent;                            -fx-border-color: #5a0011;                            -fx-border-width: 1;                            -fx-text-fill: #C0001A;                            -fx-font-family: 'Bookman Old Style';                            -fx-font-size: 13px;                            -fx-letter-spacing: 2;                            -fx-cursor: hand;" text="RETURN TO MENU">
            </Button>
        </VBox>
    </children>
</AnchorPane>
